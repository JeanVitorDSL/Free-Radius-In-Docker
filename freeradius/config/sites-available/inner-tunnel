server inner-tunnel {

  listen {
    ipaddr    = 127.0.0.1
    port      = 18120
    type      = auth
  }

  authorize {
    filter_username
    sql
    expiration
    logintime
    pap
  }

  authenticate {
    Auth-Type PAP {
      pap
    }
    Auth-Type CHAP {
      chap
    }
    Auth-Type MS-CHAP {
      mschap
    }
  }

  session {
    sql
  }

  post-auth {
    sql
    Post-Auth-Type REJECT {
      attr_filter.access_reject
    }
  }

  accounting { }
  pre-proxy  { }
  post-proxy { }
}
